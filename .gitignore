# Local IDE settings
app/public/.vscode/

# Local helper scripts (not production code)
app/public/tools/

# WordPress core (not tracked in this repo)
app/public/index.php
app/public/license.txt
app/public/readme.html
app/public/xmlrpc.php
app/public/wp-admin/
app/public/wp-includes/
app/public/wp-*.php
app/public/wp-config.php
app/public/wp-config-sample.php

# WordPress runtime cache/backups
app/public/*.zip
app/public/wp-content/uploads/
app/public/wp-content/cache/
app/public/wp-content/ai1wm-backups/
app/public/wp-content/backups-dup-lite/logs/
app/public/wp-content/backups-dup-pro/logs/
app/public/wp-content/updraft/
app/public/wp-content/upgrade-temp-backup/
