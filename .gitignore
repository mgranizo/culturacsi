app/public/wp-content/plugins/updraftplus/
app/public/wp-content/plugins/wordpress-importer/
app/public/wp-content/plugins/wp-super-cache/

# Sensitive export/diagnostic files — never commit to repo
app/public/_export/
app/public/dump_schema.php
app/public/dump_*.php
app/public/_tmp_*
app/public/.tmp_*/
app/public/i18n_*_hits.csv
app/public/site_urls.txt
app/public/sitemap_index.xml
app/public/AREA

# Production credential snapshots — MUST NOT be tracked
app/public/_legacy_scripts/live_wp_config.php
app/public/_legacy_scripts/
app/public/_deploy_backups/
app/public/_online_snapshot/
app/public/plans/

# WP-CLI binary — must not be in webroot
app/public/wp-cli.phar
app/public/*.phar

# Local rollback/debug artifacts
app/public/wp-content/mu-plugins/*.pre_rollback_*.bak
app/public/wp-content/mu-plugins/split.py
